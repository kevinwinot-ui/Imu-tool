import { reactive } from "https://esm.sh/@vue/reactivity@3.4.21";

/**
 * The IMU app uses a reactive global store.
 * This works in pure ES-modules without React Context.
 * Each module can import this store and read/write state safely.
 */

export const IMUState = reactive({

  // Active profile
  activeProfile: null,
  profiles: [],

  // Deck handling
  decklistRaw: "",
  deckParsed: [],
  deckError: null,

  // Matchup handling
  matchup: null,

  // Hand selection
  firstHand: [],
  mulliganHand: [],
  activeHand: [],
  selectingFor: null,

  // Combat & turn engine
  turn: 1,
  don: 0,
  elders: 0,

  // Battle buffs & toggles
  juPeterBuff: false,
  nusjuroDebuff: false,
  buffDon: 0,

  // Opponent info
  oppLife: 5,
  oppCounters: 0,
  oppBlockers: 0,

  // Logs
  simLog: [],

  // Settings
  settings: {
    beginnerMode: true,
    showAdvisor: true,
    showTracker: true,
    fastSim: true,
  },

  // Statistics object
  statistics: {
    totalSimulations: 0,
    totalLethals: 0,
    totalTurnsSimulated: 0,
    avgDamage: 0,
  },

  // Replay engine
  replayHistory: [],

  // UI navigation
  screen: "dashboard", // dashboard → profileSelect → deckImport → start → turnflow → killcalc → result

});

/**
 * Save profiles to localStorage
 */
export function saveProfiles() {
  localStorage.setItem("imuProfiles", JSON.stringify(IMUState.profiles));
}

/**
 * Load profiles from localStorage at boot
 */
export function loadProfiles() {
  try {
    const saved = JSON.parse(localStorage.getItem("imuProfiles") || "[]");
    if (Array.isArray(saved)) IMUState.profiles = saved;
  } catch {
    IMUState.profiles = [];
  }
}

/**
 * Switch screen
 */
export function goto(screenName) {
  IMUState.screen = screenName;
}

/**
 * Reset state for new simulation
 */
export function resetSimulation() {
  IMUState.turn = 1;
  IMUState.don = 0;
  IMUState.elders = 0;
  IMUState.activeHand = [];
  IMUState.simLog = [];
  IMUState.buffDon = 0;
  IMUState.juPeterBuff = false;
  IMUState.nusjuroDebuff = false;
}
